# RK3588 runtime config
APP_DIR=/opt/qwen25-rkllm
RUN_USER=rock
MODEL_FILE=Qwen2.5-1.5B-Instruct_W8A8_RK3588.rkllm
MAX_NEW_TOKENS=128
MAX_CONTEXT_LEN=4096
RKLLM_LOG_LEVEL=1

# demo 可执行文件和库，安装后通常位于 $APP_DIR/llm_demo 和 $APP_DIR/lib/librkllmrt.so
DEMO_BIN=llm_demo

# HTTP bridge，仅用于测试
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=18080
